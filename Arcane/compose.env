# Arcane deployment variables
# Prepared: 2026-06-08
#
# This file is committed and contains only non-secret defaults.
# Put ENCRYPTION_KEY and JWT_SECRET in compose.env.local.

GIN_MODE=release
ENVIRONMENT=production
PORT=3552
APP_URL=http://192.168.10.13:55004

DATABASE_URL=file:data/arcane.db?_pragma=journal_mode(WAL)&_pragma=busy_timeout(2500)&_txlock=immediate
ALLOW_DOWNGRADE=false

PROJECTS_DIRECTORY=/mnt/appdata/Arcane/projects
TZ=Asia/Taipei
PUID=1000
PGID=1000

# Direct Docker socket mode. This is the official simple deployment path.
# Do not expose Arcane publicly before authentication and terminal behavior are reviewed.
DOCKER_HOST=unix:///var/run/docker.sock
