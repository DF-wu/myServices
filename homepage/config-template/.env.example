# Copy to ~/workspace/myServices/homepage/.env and fill values.
# Do not commit .env.

HOMEPAGE_HOST_PORT=33080
HOMEPAGE_CONFIG_DIR=/mnt/appdata/homepage/config

# Comma-separated, no spaces. Include exact hostnames and ports used in browser.
# Example: hp.dfder.tw,axolotl.newhome:33080,192.168.10.13:33080
HOMEPAGE_ALLOWED_HOSTS=hp.dfder.tw,localhost:3000,127.0.0.1:3000,axolotl.newhome:33080

PUID=1000
PGID=1000
LOG_LEVEL=info
LOG_TARGETS=both

# Widget secrets: examples only. Fill only the widgets DF approves.
HOMEPAGE_VAR_PORTAINER_KEY=
HOMEPAGE_VAR_NPM_USERNAME=
HOMEPAGE_VAR_NPM_PASSWORD=
HOMEPAGE_VAR_ADGUARD_USERNAME=
HOMEPAGE_VAR_ADGUARD_PASSWORD=
HOMEPAGE_VAR_JELLYFIN_API_KEY=
HOMEPAGE_VAR_IMMICH_API_KEY=
HOMEPAGE_VAR_NEXTCLOUD_TOKEN=
HOMEPAGE_VAR_PHOTOPRISM_KEY=
HOMEPAGE_VAR_QBITTORRENT_USERNAME=
HOMEPAGE_VAR_QBITTORRENT_PASSWORD=
HOMEPAGE_VAR_HOMEASSISTANT_TOKEN=
HOMEPAGE_VAR_TRUENAS_API_KEY=
HOMEPAGE_VAR_TAILSCALE_API_KEY=

HOMEPAGE_VAR_BACKREST_USERNAME=
HOMEPAGE_VAR_BACKREST_PASSWORD=
HOMEPAGE_VAR_UPTIME_KUMA_SLUG=
HOMEPAGE_VAR_SPEEDTEST_API_KEY=
HOMEPAGE_VAR_CLOUDFLARED_ACCOUNT_ID=
HOMEPAGE_VAR_CLOUDFLARED_TUNNEL_ID=
HOMEPAGE_VAR_CLOUDFLARED_API_TOKEN=
HOMEPAGE_VAR_GRAFANA_USERNAME=
HOMEPAGE_VAR_GRAFANA_PASSWORD=
HOMEPAGE_VAR_SUWAYOMI_USERNAME=
HOMEPAGE_VAR_SUWAYOMI_PASSWORD=
