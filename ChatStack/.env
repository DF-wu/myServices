EXTRA_MODELS=
TGBOT_TOKEN=
OPENAPI_KEY=
TGBOTWEB_HOOK=

# lilac-mono / ChatStack shared LLM upstreams
# OPENAI_BASE_URL is for native OpenAI-format requests.
OPENAI_BASE_URL=
# OPENAI_COMPATIBLE_BASE_URL is shared by Catalina and Claudia.
# For the Anthropic-native path in lilac-mono, docker-compose currently reuses this same base URL.
# That upstream must accept BOTH OpenAI-compatible and Anthropic Messages API requests.
OPENAI_COMPATIBLE_BASE_URL=

# Per-instance keys used by lilac-mono.
OPENAI_API_KEY_CATALINA=
OPENAI_API_KEY_CLAUDIA=
OPENAI_COMPATIBLE_API_KEY_CATALINA=
OPENAI_COMPATIBLE_API_KEY_CLAUDIA=

# Optional standalone Anthropic vars are kept here for reference only.
# Current docker-compose maps ANTHROPIC_* from the OpenAI-compatible base/key per instance.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

DISCORD_TOKEN=
DISCORD_TOKEN_CLAUDIA=
GITHUB_WEBHOOK_SECRET=
GITHUB_WEBHOOK_SECRET_CLAUDIA=
GITHUB_WEBHOOK_PORT=
GITHUB_WEBHOOK_PATH=
GITHUB_TOKEN_CLAUDIA=
EXA_API_KEY=
EXA_API_BASE_URL=
TAVILY_API_BASE_URL=
TAVILY_API_KEY=
LILAC_LLM_WIRE_DEBUG=
