{
  "expo": {
    "name": "DF Voice App",
    "slug": "df-voice-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "df-voice-app",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.dfvoice.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DF Voice App records microphone audio for transcription."
      }
    },
    "android": {
      "package": "app.dfvoice.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "name": "DF Voice App",
      "shortName": "DF Voice",
      "lang": "zh-Hant",
      "scope": "/",
      "themeColor": "#18765A",
      "description": "CapsWriter and OpenAI-compatible voice workbench for ASR, chat, Responses, and TTS.",
      "dir": "ltr",
      "display": "standalone",
      "startUrl": "/",
      "orientation": "portrait",
      "backgroundColor": "#F4F7F8",
      "barStyle": "default",
      "splash": {
        "backgroundColor": "#F4F7F8",
        "resizeMode": "contain",
        "image": "./assets/splash-icon.png"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "DF Voice App records microphone audio for transcription.",
          "recordAudioAndroid": true,
          "enableBackgroundRecording": false,
          "enableBackgroundPlayback": false
        }
      ],
      "expo-secure-store",
      "expo-asset",
      "expo-system-ui",
      "./plugins/with-local-http-android",
      "expo-sharing"
    ]
  }
}
