# Public image
CAPSWRITER_SERVER_IMAGE=ghcr.io/df-wu/capswriter-offline-server:latest

# Model selection
# qwen_asr      = default, better general path for this fork
# fun_asr_nano  = faster / lighter path
CAPSWRITER_MODEL_TYPE=qwen_asr

# Qwen preset
# default      = primary preset
# low_vram_gpu = ONNX on GPU, llama on CPU
CAPSWRITER_QWEN_PRESET=default

# Inference hardware policy
# auto = prefer GPU, fall back to CPU
# gpu  = try GPU first, still fall back to CPU on failure
# cpu  = force CPU only
CAPSWRITER_INFERENCE_HARDWARE=auto

# Compose-level GPU request
# all = expose visible GPUs to the container
# 0   = CPU-only startup
CAPSWRITER_GPU_DEVICE_COUNT=all

# Networking and logs
CAPSWRITER_SERVER_PORT=6016
CAPSWRITER_LOG_LEVEL=INFO
CAPSWRITER_NUM_THREADS=16
CAPSWRITER_REMOVE_MODEL_ARCHIVES=false

# Optional OpenAI-compatible HTTP API
# If you expose this externally, set a non-empty key first.
CAPSWRITER_HTTP_API_ENABLE=true
CAPSWRITER_HTTP_API_BIND=0.0.0.0
CAPSWRITER_HTTP_API_PORT=6017
CAPSWRITER_HTTP_API_KEY=${DF_API_KEY}
CAPSWRITER_HTTP_API_MAX_UPLOAD_MB=100
CAPSWRITER_HTTP_API_TASK_TIMEOUT=600

# Optional expert tuning
CAPSWRITER_QWEN_LLAMA_N_BATCH=
CAPSWRITER_QWEN_LLAMA_N_UBATCH=
CAPSWRITER_QWEN_LLAMA_FLASH_ATTN=
CAPSWRITER_QWEN_LLAMA_OFFLOAD_KQV=