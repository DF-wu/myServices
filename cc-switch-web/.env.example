# cc-switch-web deployment defaults
# 使用方式：cp .env.example .env

# ---------- 基本入口 ----------
TZ=Asia/Taipei
CC_SWITCH_WEB_BIND_IP=127.0.0.1
CC_SWITCH_WEB_PORT=43064

# ---------- app data ----------
# 這個目錄會持久化 cc-switch.db、web_password、web_env、backups 等檔案。
CC_SWITCH_WEB_DATA_DIR=/mnt/appdata/cc-switch-web/data

# ---------- security / proxy ----------
# 目前 compose 預設走「container 內 http + host loopback + 外層反代/TLS」模型。
ALLOW_HTTP_BASIC_OVER_HTTP=1
ENABLE_HSTS=false

# 不需要跨域時留空即可。
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=
ALLOW_LAN_CORS=

# ---------- optional live config mounts ----------
# 只有在你打算取消註解 docker-compose.yml 內的對應 volumes 時才需要這些。
CLAUDE_DIR=/home/df/.claude
CLAUDE_ROOT_FILE=/home/df/.claude.json
CODEX_DIR=/home/df/.codex
GEMINI_DIR=/home/df/.gemini
OPENCODE_DIR=/home/df/.config/opencode
