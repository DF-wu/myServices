# cc-switch-web deployment defaults
# 使用方式：cp .env.example .env

TZ=Asia/Taipei
CC_SWITCH_WEB_PORT=43064
CC_SWITCH_WEB_DATA_DIR=/mnt/appdata/cc-switch-web/data
ALLOW_HTTP_BASIC_OVER_HTTP=1
ENABLE_HSTS=false
CORS_ALLOW_ORIGINS=
CORS_ALLOW_CREDENTIALS=
ALLOW_LAN_CORS=

# 若 DF 的實際主機路徑不是預設值，再改這些。
CLAUDE_DIR=/home/df/.claude
CODEX_DIR=/home/df/.codex
GEMINI_DIR=/home/df/.gemini
OPENCODE_DIR=/home/df/.config/opencode
