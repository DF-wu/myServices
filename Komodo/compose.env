####################################
# 🦎 KOMODO COMPOSE - VARIABLES 🦎 #
####################################
#
# 這份是 *committed* 模板。所有「會被推上 git」的設定放這裡。
# 真正的 secrets（密碼 / JWT secret / webhook secret）放到隔壁的 compose.env.local，
# 那個檔案被 .gitignore 排除，不會進 commit。
#
# docker-compose.yml 的 env_file 同時讀這兩份；後者覆蓋前者。
#
# 部署前 checklist（你說「先不要跑起來」，下面是啟動前必做的人工步驟）:
#   1. 生 secrets：
#        openssl rand -hex 32   # → KOMODO_WEBHOOK_SECRET
#        openssl rand -hex 32   # → KOMODO_JWT_SECRET
#        openssl rand -base64 24  # → KOMODO_DATABASE_PASSWORD
#        openssl rand -base64 18  # → KOMODO_INIT_ADMIN_PASSWORD
#      把這四個值寫進 compose.env.local（範本見該檔）。
#   2. 確認 host 目錄存在（手動 sudo mkdir，因為 periphery 是 root-in-container 會建立 root-owned 子目錄）：
#        sudo mkdir -p /etc/komodo/stacks /etc/komodo/repos
#        sudo mkdir -p /mnt/appdata/Komodo/backups
#   3. 確認 port 55003 沒被佔用：  ss -tlnp | grep 55003
#   4. 確認 KOMODO_HOST 改成你實際 LAN IP（影響 webhook 與 OAuth callback URL 顯示）。
#   5. dry-run 驗證：
#        cd /home/df/workspace/myServices/Komodo
#        docker compose --env-file compose.env --env-file compose.env.local config
#      看 yaml 解析後是否合理（特別是 secrets 沒漏）。
#   6. 確認沒問題再： docker compose up -d
#
# 之後要把 Portainer 退役時：請保留 portainer-ce 30 天當 fallback，跑通後再 docker compose down -v 它。
# ───────────────────────────────────────────────────────────────────────────

# ─── Image / 路徑 ──────────────────────────────────────────────────────────
# 注意：這個變數只是給 mongo.compose.yaml 模板用；我們的 docker-compose.yml 裡 image tag 是寫死的，
# 因此即使這裡改了也不會影響部署。保留是為了相容上游文件範例（升版時對照官方變更）。
COMPOSE_KOMODO_IMAGE_TAG="v2.1.2"

# Komodo 自動 backup 落地路徑（host 端）。走 /mnt/appdata 而不是 /etc/komodo/backups，原因：
# /etc 通常在系統碟（小），/mnt/appdata 是你資料碟（大）。Komodo backup 量會隨時間長。
COMPOSE_KOMODO_BACKUPS_PATH=/mnt/appdata/Komodo/backups

# ─── DB credentials（敏感！真值放 compose.env.local）────────────────────
# 這對帳密同時是：
#   1. mongo container 啟動時建立的 ROOT user（admin db 上的 root role）
#   2. Komodo Core 連 Mongo 用的帳密（透過 authSource=admin 認證）
# 改 username 要小心：mongo 只在「資料目錄為空」首次啟動時建帳號；之後改 env 不會生效。
# 想改既有帳密：(a) docker compose down → 砍 komodo-mongo-data volume → up（資料全失）
#              (b) 進 mongosh 跑 db.changeUserPassword() 後同步 .local。
# placeholder 寫死壞值是故意的：若忘了在 .local 複寫，容器跑不起來會被立刻發現，比靜默用弱密碼好。
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=__REPLACE_IN_compose.env.local__

# ─── Timezone ──────────────────────────────────────────────────────────────
# 跟你其他 stack（ChatStack, Dockge, Dockhand, portainer 等）一致。
TZ=Asia/Taipei

#=-------------------------=#
#= Komodo Core Environment =#
#=-------------------------=#

# Webhook / OAuth callback 顯示用的 base URL。先填 LAN IP；之後上 NPM 再改成 https://komodo.yourdomain。
# 這個值不影響 Core 監聽位址，只影響 UI 顯示與 webhook 給第三方的回呼 URL。
KOMODO_HOST=http://CHANGE_TO_YOUR_LAN_IP:55003

# 瀏覽器 tab 標題。你有多 stack，留 hostname 進去比較好辨認。
KOMODO_TITLE=Komodo @ axolotl

# Periphery 用 core 生的 ed25519 公鑰來驗證身分，反向亦然。
# 這個值是 *容器內路徑*，對應 docker-compose.yml 裡 keys named volume 掛點。不要動。
KOMODO_PERIPHERY_PUBLIC_KEY=file:/config/keys/periphery.pub

# 啟用本地帳密登入（不靠 OIDC/Oauth）。你選 LAN-only，本地登入最務實。
KOMODO_LOCAL_AUTH=true

# 第一次啟動會自動建這個 admin 帳號。username 可以照常委放這裡（不算 secret），password 必須在 .local 覆寫。
# 啟動後第一件事：登入 → 改密碼 → 把 KOMODO_INIT_ADMIN_PASSWORD 從 .local 移除（之後就靠 DB 裡的密碼）。
KOMODO_INIT_ADMIN_USERNAME=df
KOMODO_INIT_ADMIN_PASSWORD=__REPLACE_IN_compose.env.local__

# 第一次啟動自動建一台 server，名字用 host 的代號。看到你 Dockhand 注解寫 "axolotl docker group"，
# 推測這台 host 內部叫 axolotl。如果不是，改成你實際 hostname。
# 注意：PERIPHERY_CONNECT_AS（下面）必須跟這個一字不差，否則 periphery 連不上自己。
KOMODO_FIRST_SERVER_NAME=axolotl

# false = 危險操作（如 destroy stack）需要打字確認。建議保留，符合「謹慎小心」原則。
KOMODO_DISABLE_CONFIRM_DIALOG=false

# 第一次啟動會建立預設 Procedures（範例工作流）。保留 false 讓它建好範例，看完就刪。
KOMODO_DISABLE_INIT_RESOURCES=false

# Webhook 驗證 secret（GitHub / GitLab push 過來時帶這個）。MUST 在 .local 覆寫成 32+ chars 隨機。
KOMODO_WEBHOOK_SECRET=__REPLACE_IN_compose.env.local__

# JWT 簽章 secret。MUST 在 .local 覆寫；換掉這個值會踢所有人登出，是預期行為。
KOMODO_JWT_SECRET=__REPLACE_IN_compose.env.local__

# JWT 有效期。1-day 是平衡點：短到 token 流出影響有限，長到不會每天重登。
KOMODO_JWT_TTL="1-day"

# 採集間隔。15-sec 跑 70+ container 會讓 docker daemon 有點忙；如果 Netdata 同時在跑，可改 1-min 減負擔。
KOMODO_MONITORING_INTERVAL="15-sec"
# Resource auto-update 檢查間隔。1-hr 對自架夠用；想要 git push → 立刻 deploy 改 5-min。
KOMODO_RESOURCE_POLL_INTERVAL="1-hr"

# 你是 single-user，鎖死 user registration 防止萬一有人 portscan 撞到 LAN。
KOMODO_DISABLE_USER_REGISTRATION=true
KOMODO_ENABLE_NEW_USERS=false
KOMODO_DISABLE_NON_ADMIN_CREATE=false
KOMODO_TRANSPARENT_MODE=false

# OIDC / OAuth 全部關閉（你選 LAN-only + local auth）。未來想接 Google / GitHub 再開。
KOMODO_OIDC_ENABLED=false
KOMODO_GITHUB_OAUTH_ENABLED=false
KOMODO_GOOGLE_OAUTH_ENABLED=false

# AWS builder（雲端啟動 builder 機器）— 你不用，留空。
KOMODO_AWS_ACCESS_KEY_ID=
KOMODO_AWS_SECRET_ACCESS_KEY=

# Logging：保持精簡格式（適合給 Loki / journald 收）。除錯時可暫時開 true。
KOMODO_LOGGING_PRETTY=false
KOMODO_PRETTY_STARTUP_CONFIG=false

#=------------------------------=#
#= Komodo Periphery Environment =#
#=------------------------------=#

# Periphery 連 core 的 WebSocket 位址。用 service name 走 docker DNS，不要寫 IP。
PERIPHERY_CORE_ADDRESS=ws://core:9120

# Periphery 自報的 server 名字。MUST === KOMODO_FIRST_SERVER_NAME，否則 core 端配對失敗。
PERIPHERY_CONNECT_AS=${KOMODO_FIRST_SERVER_NAME}

# 反向：core 的 public key 由 core 寫入共享 volume，periphery 從這條讀。
PERIPHERY_CORE_PUBLIC_KEYS=file:/config/keys/core.pub

# Periphery 的 ROOT_DIRECTORY（容器內路徑）。
# 你選了官方建議的 /etc/komodo（隔離模式 — 不接管現有 stacks）。
# host 端的 mount 點在 docker-compose.yml 裡是 symmetric 的同路徑。
PERIPHERY_ROOT_DIRECTORY=/etc/komodo

# Terminal 功能：透過 UI 開 shell 進 periphery 容器。
# false = 啟用。periphery 容器是 root-in-container，能 shell 進去 = 等同 host root。
# ⚠️ 你是單人使用、LAN-only、admin 帳號有 JWT 保護，所以開著沒問題。
# 若之後對外（NPM）暴露，強烈建議改 true 鎖死。
PERIPHERY_DISABLE_TERMINALS=false
PERIPHERY_DISABLE_CONTAINER_TERMINALS=false

# 磁碟監控白名單。Komodo 預設會把所有 mount 都報出來（含 docker overlay、tmpfs），數字會誇張。
# 用 /etc/hostname 這個 trick 是官方推薦：只回報根 fs，數字才對得上 `df -h`。
PERIPHERY_INCLUDE_DISK_MOUNTS=/etc/hostname

PERIPHERY_LOGGING_PRETTY=false
PERIPHERY_PRETTY_STARTUP_CONFIG=false
