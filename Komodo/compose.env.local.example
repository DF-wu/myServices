# ───────────────────────────────────────────────────────────────────────────
# 這是 *範本*。實際使用時：
#   1. cp compose.env.local.example compose.env.local
#   2. 把所有 __FILL_ME__ 用下面 openssl 指令的輸出取代
#   3. compose.env.local 已被 .gitignore 排除，不會推上去
# ───────────────────────────────────────────────────────────────────────────
#
# 生 secrets 的指令（在你的 shell 跑一次，把輸出貼下來）：
#   openssl rand -base64 24       # KOMODO_DATABASE_PASSWORD
#   openssl rand -base64 18       # KOMODO_INIT_ADMIN_PASSWORD（給人記的，短一點）
#   openssl rand -hex 32          # KOMODO_WEBHOOK_SECRET
#   openssl rand -hex 32          # KOMODO_JWT_SECRET
#
# 為什麼用不同長度：
# - DB password 不會給人輸入，base64-24 (192 bit) 夠安全且 postgres 接受。
# - admin password 一開始要登入用，太長很難 paste；首次登入後立刻在 UI 改密碼，這個值就過期了。
# - webhook / jwt secret 是 server-to-server，越長越好，hex-32 (256 bit) 是業界基準。

# ─── DB ────────────────────────────────────────────────────────────────────
KOMODO_DATABASE_PASSWORD=__FILL_ME__

# ─── Initial admin（首次登入後改密碼，然後可以從這檔案移除）─────────────
KOMODO_INIT_ADMIN_PASSWORD=__FILL_ME__

# ─── Server-to-server secrets（換掉會踢所有人登出 / 讓現有 webhook 失效）─
KOMODO_WEBHOOK_SECRET=__FILL_ME__
KOMODO_JWT_SECRET=__FILL_ME__
