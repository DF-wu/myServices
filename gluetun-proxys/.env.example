# Gluetun Proxy Farm - 環境變數設定範例
# 複製此檔案為 .env 並填入實際數值

# ═══════════════════════════════════════════════════════════
# Surfshark WireGuard 設定（必填）
# ═══════════════════════════════════════════════════════════

# WireGuard Private Key
# 取得方式：Surfshark 帳號 → VPN → Manual Setup → WireGuard → Generate keypair
# 複製 Private Key 的值填入下方
WIREGUARD_PRIVATE_KEY=your_surfshark_wireguard_private_key_here

# WireGuard 介面位址
# 通常為 10.14.0.2/16，但請以 Surfshark 提供的設定為準
WIREGUARD_ADDRESSES=10.14.0.2/16

# Shadowsocks 設定
SHADOWSOCKS_PASSWORD=your_strong_password_here
SHADOWSOCKS_CIPHER=aes-256-gcm
# ═══════════════════════════════════════════════════════════

# 時區設定
TZ=Asia/Taipei

# ═══════════════════════════════════════════════════════════
# 網路設定
# ═══════════════════════════════════════════════════════════

# 區網子網路（讓區網內其他裝置可以連到 proxy）
# 請依實際區網設定調整，常見值：
# - 192.168.0.0/24
# - 192.168.1.0/24
# - 10.0.0.0/24
LAN_SUBNET=192.168.1.0/24
