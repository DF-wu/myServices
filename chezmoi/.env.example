# chezmoi manual runner sample environment.
# Copy to `.env` only when you are ready to run compose locally.
# Do not commit the real `.env` if it contains private repo URLs or machine paths.

TZ=Asia/Taipei
PUID=1000
PGID=1000

# Pinned to the latest release checked during evaluation on 2026-06-08.
CHEZMOI_TAG=v2.70.5

# Host paths.
CHEZMOI_TARGET_HOME=/home/df
CHEZMOI_SOURCE_DIR=/mnt/appdata/chezmoi/source
CHEZMOI_CACHE_DIR=/mnt/appdata/chezmoi/cache

# Safe default: prints help only, no init/apply.
CHEZMOI_ARGS=--help

# Useful manual overrides:
# CHEZMOI_ARGS=doctor
# CHEZMOI_ARGS=diff
# CHEZMOI_ARGS=init --source=/chezmoi-source git@github.com:USER/dotfiles.git
# CHEZMOI_ARGS=apply --verbose
