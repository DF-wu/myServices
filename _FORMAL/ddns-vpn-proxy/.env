# Timezone used in logs.
TZ=Asia/Taipei

# Directory containing your source OpenVPN files.
# Put exactly one .ovpn under ./config/openvpn/ unless OPENVPN_SOURCE_CONFIG is set.
OPENVPN_CONFIG_DIR=/root/appdata/ddns-vpn-proxy/config

# Optional explicit path to the source .ovpn profile.
# Leave blank to auto-detect the only .ovpn in ./config/openvpn/.
OPENVPN_SOURCE_CONFIG=

# Directory for rendered runtime state.
STATE_DIR=/root/appdata/ddns-vpn-proxy/state

# Optional explicit hostname to watch.
# Leave blank to parse the hostname from the primary 'remote' line in the source .ovpn.
DDNS_HOSTNAME=

# Polling and restart debounce.
DDNS_POLL_SECONDS=60
DDNS_COOLDOWN_SECONDS=15

# Optional DNS resolver IP for the watcher. Leave blank to use the container default resolver.
DDNS_RESOLVER=

# HTTP proxy listener published from Gluetun.
HTTP_PROXY_PORT=28888

# Name of the Gluetun container to restart when the DDNS target changes.
GLUETUN_CONTAINER_NAME=ddns-openvpn-proxy

# Published watcher image. This image runs both ddns-init and ddns-watcher.
WATCHER_IMAGE=ghcr.io/df-wu/ddns-openvpn-proxy-watcher:latest

# Optional explicit source config path inside the mounted source directory contract.
# Example: ./config/openvpn/client.ovpn
# Leave blank to auto-detect the only .ovpn file.
# OPENVPN_SOURCE_CONFIG=./config/openvpn/client.ovpn

# Gluetun image reference.
GLUETUN_IMAGE=qmcgaw/gluetun:latest

# Optional: test override only. Leave empty in normal use.
DDNS_OVERRIDE_IP=